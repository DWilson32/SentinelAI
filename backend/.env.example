DATABASE_URL=sqlite:///./sentinel.db
GNEWS_API_KEY=
NEWS_API_KEY=

# Vector RAG (local Qdrant storage by default; set QDRANT_URL for a remote instance)
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_PATH=./qdrant_data
QDRANT_COLLECTION=sentinel_sources

# Local embeddings via FastEmbed (default). Optional OpenAI for embeddings + answers.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384
USE_OPENAI_EMBEDDINGS=false
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
RAG_TOP_K=4

# LangGraph agents + RAG chat use OPENAI_API_KEY when set; rule-based fallback otherwise
