{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: create venv",
      "type": "shell",
      "command": "py",
      "args": ["-3.12", "-m", "venv", ".venv"],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    },
    {
      "label": "Backend: install deps",
      "type": "shell",
      "command": "${workspaceFolder}/backend/.venv/Scripts/python.exe",
      "args": ["-m", "pip", "install", "-r", "requirements.txt"],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    },
    {
      "label": "Backend: dev",
      "type": "shell",
      "command": "${workspaceFolder}/backend/.venv/Scripts/uvicorn.exe",
      "args": ["app.main:app", "--reload", "--host", "127.0.0.1", "--port", "8000"],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "python",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^INFO:.*Started reloader process|^INFO:.*Started server process",
          "endsPattern": "^INFO:.*Application startup complete"
        }
      },
      "presentation": {
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Frontend: install deps",
      "type": "shell",
      "command": "npm",
      "args": ["install"],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend: dev",
      "type": "shell",
      "command": "${workspaceFolder}/frontend/node_modules/.bin/next.CMD",
      "args": ["dev", "--hostname", "127.0.0.1", "--port", "3000"],
      "options": {
        "cwd": "${workspaceFolder}/frontend",
        "env": {
          "NEXT_PUBLIC_API_BASE_URL": "http://127.0.0.1:8000/api"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Next\\.js.*|^.*Starting.*",
          "endsPattern": "^.*Ready in.*"
        }
      },
      "presentation": {
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Full stack: dev",
      "dependsOn": ["Backend: dev", "Frontend: dev"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "Backend: health check",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-Command",
        "Invoke-RestMethod http://127.0.0.1:8000/health"
      ],
      "problemMatcher": []
    },
    {
      "label": "Frontend: typecheck",
      "type": "shell",
      "command": "${workspaceFolder}/frontend/node_modules/.bin/tsc.CMD",
      "args": ["--noEmit"],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": "$tsc"
    }
  ]
}
